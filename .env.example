# Copy this file to .env and change the values for your cameras.

# Entry camera
HIKVISION_IN_IP=192.168.1.64
HIKVISION_IN_USERNAME=admin
HIKVISION_IN_PASSWORD=change_me
HIKVISION_IN_RTSP_PORT=554
HIKVISION_IN_CHANNEL=101

# Exit camera
HIKVISION_OUT_IP=192.168.1.65
HIKVISION_OUT_USERNAME=admin
HIKVISION_OUT_PASSWORD=change_me
HIKVISION_OUT_RTSP_PORT=554
HIKVISION_OUT_CHANNEL=101

# Alternative: instead of IP/username/password fields, you can use full RTSP URLs.
# HIKVISION_IN_RTSP=rtsp://admin:change_me@192.168.1.64:554/Streaming/Channels/101
# HIKVISION_OUT_RTSP=rtsp://admin:change_me@192.168.1.65:554/Streaming/Channels/101

# Face verification tuning
# Lower values are stricter. Try 0.45 if you get false matches, 0.55 if valid employees are missed.
FACE_MATCH_TOLERANCE=0.5
UNKNOWN_FACE_TOLERANCE=0.5
DETECTION_COOLDOWN_MINUTES=2
UNKNOWN_RECORDING_SECONDS=30
STREAM_FPS=10
APP_PORT=5000
