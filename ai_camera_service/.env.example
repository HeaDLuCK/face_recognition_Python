APP_NAME="AI Camera Service"
ENVIRONMENT=development
LOG_LEVEL=INFO

ERP_BASE_URL=
ERP_API_TOKEN=

MONGO_URL=mongodb://localhost:27017
MONGO_DB_NAME=ai_camera_service

SNAPSHOT_DIR=snapshots

DEFAULT_RECOGNITION_THRESHOLD=0.55
DEFAULT_DUPLICATE_COOLDOWN_SECONDS=60

INSIGHTFACE_MODEL_NAME=buffalo_l
INSIGHTFACE_PROVIDERS=CPUExecutionProvider
INSIGHTFACE_CTX_ID=-1

CAMERA_FRAME_SKIP=5
RECOGNITION_INTERVAL_SECONDS=1.0

# auto: use usb://0 or numeric camera sources as USB, RTSP URLs as IP streams
# usb: force local USB webcam using USB_CAMERA_INDEX
# rtsp: force ERP camera URLs as RTSP/IP streams
CAMERA_SOURCE_MODE=auto
USB_CAMERA_INDEX=0
RTSP_URL=
RTSP_URLS=
RTSP_CHANNELS=
DEV_TENANT_ID=DEV_COMPANY
DEV_CAMERA_ID=USB_CAM_01
STREAM_FPS=20
STREAM_JPEG_QUALITY=80
SHOW_DEV_FPS=true
SHOW_DEV_DETECTIONS=true
DRAW_FACE_BOXES_ON_SNAPSHOTS=true
DRAW_FACE_LABELS_ON_SNAPSHOTS=true

# Optional outbound cloud stream push. Leave empty to disable.
CLOUD_STREAM_WS_URL=
CLOUD_STREAM_TOKEN=
CLOUD_STREAM_FPS=10
CLOUD_STREAM_RECONNECT_SECONDS=5

EVENT_CLIP_DIR=event_clips
EVENT_BUFFER_SECONDS=30
EVENT_CLIP_FPS=15
EVENT_CLIP_COOLDOWN_SECONDS=30

# Polygon zones to watch for motion/change.
# Format: zone_id:x,y|x,y|x,y;another_zone:x,y|x,y|x,y|x,y
# Example: MOTION_ZONES=door:100,120|420,120|420,360|100,360
MOTION_ZONES=
MOTION_CHECK_FRAME_SKIP=5
MOTION_PIXEL_THRESHOLD=35
MOTION_AREA_RATIO=0.02
SHOW_MOTION_ZONES=true
