APP_NAME="AI Camera Service"
ENVIRONMENT=development
LOG_LEVEL=INFO

ERP_BASE_URL=
ERP_API_TOKEN=

MONGO_URL=mongodb://localhost:27017
MONGO_DB_NAME=ai_camera_service

SNAPSHOT_DIR=snapshots

DEFAULT_RECOGNITION_THRESHOLD=0.55
DEFAULT_DUPLICATE_COOLDOWN_SECONDS=60

INSIGHTFACE_MODEL_NAME=buffalo_l
INSIGHTFACE_PROVIDERS=CPUExecutionProvider
INSIGHTFACE_CTX_ID=-1

CAMERA_FRAME_SKIP=5
RECOGNITION_INTERVAL_SECONDS=1.0

# auto: use usb://0 or numeric camera sources as USB, RTSP URLs as IP streams
# usb: force local USB webcam using USB_CAMERA_INDEX
# rtsp: force ERP camera URLs as RTSP/IP streams
CAMERA_SOURCE_MODE=auto
USB_CAMERA_INDEX=0
DEV_TENANT_ID=DEV_COMPANY
DEV_CAMERA_ID=USB_CAM_01
STREAM_FPS=20
STREAM_JPEG_QUALITY=80
SHOW_DEV_FPS=true
SHOW_DEV_DETECTIONS=true
