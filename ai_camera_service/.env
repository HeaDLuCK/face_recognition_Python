ENVIRONMENT=development
ERP_BASE_URL=
# CAMERA_SOURCE_MODE=usb
# USB_CAMERA_INDEX=0
# DEV_TENANT_ID=DEV_COMPANY
# DEV_CAMERA_ID=USB_CAM_01

CAMERA_SOURCE_MODE=rtsp
RTSP_URL=rtsp://admin:CalAbc998%3F!@192.168.100.5:554/Streaming/Channels/101
RTSP_CHANNELS=101,102,201,202,301,401,402,501,502,601,602,701,702,801,802

MONGO_URL=mongodb://localhost:27017
MONGO_DB_NAME=ai_camera_service

STREAM_FPS=30
STREAM_JPEG_QUALITY=80
SHOW_DEV_FPS=false
CAMERA_FRAME_SKIP=15
RECOGNITION_INTERVAL_SECONDS=2.0
SHOW_DEV_DETECTIONS=false
DRAW_FACE_BOXES_ON_SNAPSHOTS=true
DRAW_FACE_LABELS_ON_SNAPSHOTS=true
CLOUD_STREAM_WS_URL=
CLOUD_STREAM_TOKEN=
CLOUD_STREAM_FPS=10
CLOUD_STREAM_RECONNECT_SECONDS=5

EVENT_CLIP_DIR=event_clips
EVENT_BUFFER_SECONDS=30
EVENT_CLIP_FPS=15
EVENT_CLIP_COOLDOWN_SECONDS=30
MOTION_CHECK_FRAME_SKIP=5
MOTION_PIXEL_THRESHOLD=35
MOTION_AREA_RATIO=0.02
SHOW_MOTION_ZONES=true


MOTION_ZONES=door:100,120|420,120|420,360|100,360;shelf:600,150|900,150|900,500|600,500
SHOW_DEV_DETECTIONS=true
